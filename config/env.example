# paperboy — runtime config (copy to /etc/paperboy/paperboy.env or .env)

# --- Discord delivery (REQUIRED) ----------------------------------------
# Either set DISCORD_WEBHOOK, OR set DISCORD_BOT_TOKEN + DISCORD_CHANNEL_ID.
# If both are set, the bot path is preferred; webhook is the fallback.
DISCORD_WEBHOOK=
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# --- Ollama (REQUIRED for scoring + news scanner) -----------------------
OLLAMA_URL=http://127.0.0.1:11434

# --- Storage ------------------------------------------------------------
# Where the SQLite events.db lives. Defaults to ~/.paperboy/
PAPERBOY_ROOT=/var/lib/paperboy
# PAPERBOY_DB= /var/lib/paperboy/events.db    # override path if needed

# --- Model choices ------------------------------------------------------
# Fast 3B model for the news-opinion drafter (short JSON outputs)
NEWS_MODEL=llama3.2:3b
# Larger model for paper scoring — needs strong JSON adherence + reasoning
PAPERBOY_RESEARCH_MODEL=qwen2.5:7b
# Reframer for prompt_digest (when PROMPT_DIGEST_REFRAME=1)
PROMPT_DIGEST_MODEL=llama3.2:3b

# --- Knobs (all optional, defaults shown) -------------------------------
NEWS_MAX_PER_VERTICAL=2
PAPERS_MIN_RELEVANCE=7
PAPERS_MAX_PER_RUN=5
PAPERS_LOOKBACK_HOURS=24
TOPICAL_PICKS_PER_RUN=2
TOPICAL_RECENT_DAYS=21
TODAY_MAX_PER_RUN=6
PROMPT_DIGEST_LIMIT=12
PROMPT_DIGEST_LOOKBACK_HOURS=48
PROMPT_DIGEST_REFRAME=0

# --- Optional: link back to a dashboard URL in the morning digest -------
# PAPERBOY_DASHBOARD_URL=http://your-host:8766/

# --- Optional: override config paths (default: /etc/paperboy/) ---------
# NEWS_SOURCES=/etc/paperboy/news_sources.yaml
# RESEARCH_SOURCES=/etc/paperboy/research-sources.json
# RESEARCH_INTERESTS=/etc/paperboy/research-interests.md
# TOPICAL_MAP=/etc/paperboy/topical-map.md
# DAILY_BRIEFS_DIR=/var/lib/paperboy/daily-briefs
