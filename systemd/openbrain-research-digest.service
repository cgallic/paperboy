[Unit]
Description=openbrain: post top-3 newly-scored papers to Discord
After=network.target openbrain-research-score.service
Documentation=https://github.com/cgallic/openbrain

[Service]
Type=oneshot
EnvironmentFile=-/etc/openbrain/openbrain.env
ExecStart=/usr/bin/env python3 -m openbrain.digest.research_digest --top 3 --min-relevance 7 --verbose
StandardOutput=journal
StandardError=journal
TimeoutStartSec=600
