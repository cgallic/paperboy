[Unit]
Description=paperboy: promote top-scored papers into the morning queue
After=network.target paperboy-research-score.service
Documentation=https://github.com/cgallic/paperboy

[Service]
Type=oneshot
EnvironmentFile=-/etc/paperboy/paperboy.env
ExecStart=/usr/bin/env python3 -m paperboy.scanners.papers_to_prompts
StandardOutput=journal
StandardError=journal
TimeoutStartSec=120
