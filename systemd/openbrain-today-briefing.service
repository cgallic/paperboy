[Unit]
Description=openbrain: parse today's daily-brief markdown for carry-overs
After=network.target
Documentation=https://github.com/cgallic/openbrain

[Service]
Type=oneshot
EnvironmentFile=-/etc/openbrain/openbrain.env
ExecStart=/usr/bin/env python3 -m openbrain.scanners.today_briefing
StandardOutput=journal
StandardError=journal
TimeoutStartSec=120
